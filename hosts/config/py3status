general {
        separator = "|"
        colors = true
}

py3status {
        separator = "|"
}

order += "external_script prs"
order += "battery_level"
order += "disk /"
order += "cpu_usage"
order += "memory"
order += "tztime local"

battery_level {
        format = "bat: {percent}% {power:.1f}W"
        battery_id = 0
        measurement_mode = "sys"
        hide_seconds = true
        notification = true
        cache_timeout = 5
}

disk "/" {
        format = "disk: %percentage_used"
}

tztime local {
        format = "%H:%M:%S %Z"
}

cpu_usage {
        format = "cpu: %usage"
        degraded_threshold = "25"
}

memory {
        format = "mem: %percentage_used"
        threshold_degraded = "10%"
}

external_script "prs" {
        format = "prs: {output}"
        script_path = "mypulls"
        cache_timeout = 150
        on_click 3 = "exec xdg-open https://github.com/pulls/review-requested"
}

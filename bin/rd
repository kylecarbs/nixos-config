#!/usr/bin/env bash

arg="${1:?Usage: rd [user@]host:path | host:path | path}"

if [[ "$arg" == *:* ]]; then
  host="${arg%%:*}"
  host="${host##*@}"
  path="${arg#*:}"
else
  host="dev"
  path="$arg"
fi

if ! ssh "$host" "test -d $path"; then
  echo "error: $host:$path does not exist" >&2
  exit 1
fi

exec cursor --remote "ssh-remote+$host" "$path"

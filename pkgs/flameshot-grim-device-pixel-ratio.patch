From: Kyle Local Packaging <kyle@example.invalid>
Subject: [PATCH] flameshot: preserve Wayland output scale for grim captures

On Sway/Wayland, Flameshot captures through grim and then crops the full
desktop image using logical screen geometry. On HiDPI or mixed-DPI outputs,
the raw pixmap is in physical pixels while the selected screen geometry is in
logical pixels, so Flameshot crops the wrong region or captures the wrong
monitor. Preserve the grim image devicePixelRatio and scale the crop rectangle
so screenshots line up with the active output.

diff --git a/src/utils/screengrabber.cpp b/src/utils/screengrabber.cpp
index 3884eef8..8d75eddd 100644
--- a/src/utils/screengrabber.cpp
+++ b/src/utils/screengrabber.cpp
@@ -42,6 +42,13 @@ void ScreenGrabber::generalGrimScreenshot(bool& ok, QPixmap& res)
     Process.start(program, arguments);
     if (Process.waitForFinished()) {
         res.load(imgPath, "ppm");
+        QRect logicalGeo = logicalDesktopGeometry();
+        if (!res.isNull() && !logicalGeo.isEmpty() &&
+            res.size() != logicalGeo.size()) {
+            res.setDevicePixelRatio(res.height() * 1.0f /
+                                    logicalGeo.height());
+        }
+
         QFile imgFile(imgPath);
         imgFile.remove();
         ok = true;
@@ -254,7 +261,14 @@ QPixmap ScreenGrabber::grabScreen(QScreen* screen, bool& ok)
     if (m_info.waylandDetected()) {
         p = grabEntireDesktop(ok);
         if (ok) {
-            return p.copy(geometry);
+            qreal dpr = p.devicePixelRatio();
+            QRect scaledGeometry(qRound(geometry.x() * dpr),
+                                 qRound(geometry.y() * dpr),
+                                 qRound(geometry.width() * dpr),
+                                 qRound(geometry.height() * dpr));
+            QPixmap screenPixmap = p.copy(scaledGeometry);
+            screenPixmap.setDevicePixelRatio(dpr);
+            return screenPixmap;
         }
     } else {
         ok = true;
diff --git a/src/widgets/capture/capturewidget.cpp b/src/widgets/capture/capturewidget.cpp
index c1628d6e..0fb9489c 100644
--- a/src/widgets/capture/capturewidget.cpp
+++ b/src/widgets/capture/capturewidget.cpp
@@ -107,7 +107,27 @@ CaptureWidget::CaptureWidget(const CaptureRequest& req,
     if (fullScreen) {
         // Grab Screenshot
         bool ok = true;
-        m_context.screenshot = ScreenGrabber().grabEntireDesktop(ok);
+#if defined(Q_OS_LINUX) || defined(Q_OS_UNIX)
+        if (qEnvironmentVariableIsSet("WAYLAND_DISPLAY")) {
+            QScreen* captureScreen = QGuiAppCurrentScreen().currentScreen();
+            const QString outputName =
+              qEnvironmentVariable("FLAMESHOT_WAYLAND_OUTPUT");
+            if (!outputName.isEmpty()) {
+                for (QScreen* const screen : QGuiApplication::screens()) {
+                    if (screen->name() == outputName) {
+                        captureScreen = screen;
+                        break;
+                    }
+                }
+            }
+            m_context.screenshot =
+              ScreenGrabber().grabScreen(captureScreen, ok);
+        } else {
+            m_context.screenshot = ScreenGrabber().grabEntireDesktop(ok);
+        }
+#else
+        m_context.screenshot = ScreenGrabber().grabEntireDesktop(ok);
+#endif
         if (!ok) {
             AbstractLogger::error() << tr("Unable to capture screen");
             this->close();

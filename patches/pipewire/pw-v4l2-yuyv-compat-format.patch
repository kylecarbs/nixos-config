+static bool is_compat_format(uint32_t fourcc)
+{
+	return fourcc == V4L2_PIX_FMT_YUYV;
+}
+
+#define COMPAT_DEFAULT_WIDTH		1920u
+#define COMPAT_DEFAULT_HEIGHT		1080u
+#define COMPAT_DEFAULT_FPS_NUM		30u
+#define COMPAT_DEFAULT_FPS_DENOM	1u
+
+static bool is_compat_size(uint32_t width, uint32_t height)
+{
+	return width <= COMPAT_DEFAULT_WIDTH && height <= COMPAT_DEFAULT_HEIGHT;
+}
+
+static int fill_format_from_fourcc(struct v4l2_format *fmt,
+		uint32_t fourcc, uint32_t width, uint32_t height)
+{
+	const struct format_info *fi;
+
+	fi = format_info_from_fourcc(fourcc);
+	if (fi == NULL)
+		return -EINVAL;
+	if (width == 0 || height == 0)
+		return -EINVAL;
+
+	spa_zero(*fmt);
+	fmt->type = V4L2_BUF_TYPE_VIDEO_CAPTURE;
+	fmt->fmt.pix.pixelformat = fi->fourcc;
+	fmt->fmt.pix.field = V4L2_FIELD_NONE;
+	fmt->fmt.pix.width = width;
+	fmt->fmt.pix.height = height;
+	fmt->fmt.pix.colorspace = V4L2_COLORSPACE_SRGB;
+	fmt->fmt.pix.bytesperline =
+		SPA_ROUND_UP_N(fmt->fmt.pix.width, 4) * fi->bpp;
+	fmt->fmt.pix.sizeimage = fmt->fmt.pix.bytesperline *
+		SPA_ROUND_UP_N(fmt->fmt.pix.height, 2);
+
+	return 0;
+}
+
+static bool format_param_has_size(const struct spa_pod *param,
+		uint32_t width, uint32_t height)
+{
+	const struct spa_pod_prop *size_prop;
+	const struct spa_pod *size_pods;
+	const struct spa_rectangle *sizes;
+	uint32_t n_sizes, choice;
+
+	size_prop = spa_pod_find_prop(param, NULL, SPA_FORMAT_VIDEO_size);
+	if (size_prop == NULL)
+		return false;
+
+	size_pods = spa_pod_get_values(&size_prop->value, &n_sizes, &choice);
+	if (size_pods == NULL || n_sizes == 0)
+		return false;
+
+	sizes = SPA_POD_BODY_CONST(size_pods);
+	if (size_pods->type != SPA_TYPE_Rectangle || size_pods->size != sizeof(*sizes))
+		return false;
+
+	switch (choice) {
+	case SPA_CHOICE_Enum:
+		n_sizes -= 1;
+		sizes += 1;
+		SPA_FALLTHROUGH;
+	case SPA_CHOICE_None:
+		for (size_t i = 0; i < n_sizes; i++) {
+			if (sizes[i].width == width && sizes[i].height == height)
+				return true;
+		}
+		return false;
+	case SPA_CHOICE_Range:
+		if (n_sizes < 3)
+			return false;
+		return width >= sizes[1].width && width <= sizes[2].width &&
+			height >= sizes[1].height && height <= sizes[2].height;
+	case SPA_CHOICE_Step:
+		if (n_sizes < 4 || sizes[3].width == 0 || sizes[3].height == 0)
+			return false;
+		if (width < sizes[1].width || width > sizes[2].width ||
+		    height < sizes[1].height || height > sizes[2].height)
+			return false;
+		return (width - sizes[1].width) % sizes[3].width == 0 &&
+			(height - sizes[1].height) % sizes[3].height == 0;
+	default:
+		return false;
+	}
+}
+
+static bool compat_size_supported_locked(struct file *file,
+		uint32_t width, uint32_t height)
+{
+	struct param *p;
+
+	if (file->node == NULL)
+		return false;
+
+	spa_list_for_each(p, &file->node->param_list, link) {
+		uint32_t media_type, media_subtype;
+
+		if (p->id != SPA_PARAM_EnumFormat || p->param == NULL)
+			continue;
+
+		if (spa_format_parse(p->param, &media_type, &media_subtype) < 0)
+			continue;
+		if (media_type != SPA_MEDIA_TYPE_video)
+			continue;
+
+		if (format_param_has_size(p->param, width, height))
+			return true;
+	}
+
+	return false;
+}
+
+static int fill_compat_format_locked(struct file *file, struct v4l2_format *fmt,
+		uint32_t fourcc, uint32_t width, uint32_t height)
+{
+	if (!is_compat_format(fourcc))
+		return -EINVAL;
+
+	if (!is_compat_size(width, height))
+		return -EINVAL;
+
+	if (!compat_size_supported_locked(file, width, height))
+		return -EINVAL;
+
+	return fill_format_from_fourcc(fmt, fourcc, width, height);
+}
+
+static int fill_default_compat_format_locked(struct file *file,
+		struct v4l2_format *fmt)
+{
+	return fill_compat_format_locked(file, fmt, V4L2_PIX_FMT_YUYV,
+			COMPAT_DEFAULT_WIDTH, COMPAT_DEFAULT_HEIGHT);
+}

+
+	pw_thread_loop_lock(file->loop);
+	found = compat_size_supported_locked(file, arg->width, arg->height);
+	pw_thread_loop_unlock(file->loop);
+
+	if (!found)
+		return -EINVAL;
+
+	arg->type = V4L2_FRMIVAL_TYPE_DISCRETE;
+	arg->discrete.numerator = COMPAT_DEFAULT_FPS_DENOM;
+	arg->discrete.denominator = COMPAT_DEFAULT_FPS_NUM;
+	memset(arg->reserved, 0, sizeof(arg->reserved));
+
+	return 0;
